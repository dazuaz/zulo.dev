# Resend API key — https://resend.com/api-keys
RESEND_API_KEY=

# Where contact form submissions are delivered
CONTACT_TO_EMAIL=danielzuloaga@gmail.com

# Sender for contact form emails.
# Leave unset to use Resend's testing sender (onboarding@resend.dev),
# which only delivers to the Resend account-owner address.
# For production, verify a domain at https://resend.com/domains
# and set this to e.g. 'Daniel Zuloaga <hello@zulo.dev>'.
CONTACT_FROM_EMAIL=
