---
import Layout from './Layout.astro';
import PromptCopyEnhancer from '../components/PromptCopyEnhancer';

const { title, description, pubDate, updatedDate, tags, heroImage, heroImageAlt, slug } = Astro.props;
const formatter = new Intl.DateTimeFormat('en-US', { dateStyle: 'long' });
const publishedLabel = formatter.format(pubDate);
const updatedLabel = updatedDate ? formatter.format(updatedDate) : null;
---

<Layout title={`${title} | Daniel Zuloaga`} description={description}>
  <main class="px-4 py-12 sm:px-6 lg:px-10">
    <article class="mx-auto flex max-w-3xl flex-col gap-6">
      <a
        class="inline-flex w-fit items-center rounded-full border border-slate-300 bg-white px-4 py-2 text-xs font-semibold uppercase tracking-[0.16em] text-slate-700 transition hover:border-slate-400"
        href="/blog"
      >
        Back to blog
      </a>

      <header class="soft-surface rounded-3xl p-6 sm:p-8">
        <p class="text-xs font-semibold uppercase tracking-[0.24em] text-sky-800">Post</p>
        <h1 class="mt-2 text-3xl font-semibold tracking-tight text-slate-900 sm:text-4xl">{title}</h1>
        <p class="mt-3 text-base text-slate-700 sm:text-lg">{description}</p>

        <div class="mt-4 flex flex-wrap items-center gap-3 text-xs font-semibold uppercase tracking-[0.16em] text-slate-500">
          <span>{publishedLabel}</span>
          {updatedLabel && <span>Updated {updatedLabel}</span>}
        </div>

        {
          tags?.length ? (
            <div class="mt-4 flex flex-wrap gap-2">
              {tags.map((tag) => (
                <span class="rounded-full border border-slate-300 bg-white px-3 py-1 text-[11px] font-semibold uppercase tracking-[0.12em] text-slate-600">
                  {tag}
                </span>
              ))}
            </div>
          ) : null
        }
      </header>

      {
        heroImage ? (
          <figure class="soft-surface rounded-3xl p-3 sm:p-4">
            <img
              class="blog-hero-image"
              src={heroImage}
              alt={heroImageAlt ?? `${title} main image`}
              loading="eager"
              decoding="async"
            />
          </figure>
        ) : null
      }

      <div class="soft-surface rounded-3xl p-6 sm:p-8">
        <div class="blog-content">
          <slot />
        </div>
      </div>
    </article>
  </main>
  <PromptCopyEnhancer client:load slug={slug} />
</Layout>
