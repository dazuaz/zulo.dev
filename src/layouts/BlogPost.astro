---
import Layout from './Layout.astro';
import PromptCopyEnhancer from '../components/PromptCopyEnhancer';

const {
  title,
  description,
  pubDate,
  updatedDate,
  tags,
  heroImage,
  heroImageAlt,
  slug,
  minutes,
  newerPost,
  olderPost,
} = Astro.props;
const formatter = new Intl.DateTimeFormat('en-US', { dateStyle: 'long' });
const publishedLabel = formatter.format(pubDate);
const updatedLabel = updatedDate ? formatter.format(updatedDate) : null;
---

<Layout
  title={`${title} | Daniel Zuloaga`}
  description={description}
  ogType="article"
  ogImage={heroImage ?? '/og.jpg'}
  pubDate={pubDate}
  updatedDate={updatedDate}
  nav="blog"
>
  <main id="main-content">
    <article class="page-shell section-block--end">
      <header class="page-intro article-header">
        <nav class="breadcrumb" aria-label="Breadcrumb">
          <a class="focus-ring" href="/">Home</a>
          <span class="breadcrumb-sep" aria-hidden="true">/</span>
          <a class="focus-ring" href="/blog">Writing</a>
          <span class="breadcrumb-sep" aria-hidden="true">/</span>
          <span aria-current="page">{title}</span>
        </nav>
        <h1 class="display-title measure-article-title">{title}</h1>
        <p class="prose-lead">{description}</p>

        <div class="article-meta meta-date">
          <time datetime={pubDate.toISOString()}>{publishedLabel}</time>
          {minutes && <span>{minutes} min read</span>}
          {updatedLabel && <span>Updated {updatedLabel}</span>}
        </div>

        {
          tags?.length ? (
            <div class="cluster-md">
              {tags.map((tag) => (
                <span class="tag">{tag}</span>
              ))}
            </div>
          ) : null
        }
      </header>

      <div class="article-measure">
        {
          heroImage ? (
            <figure class="section-rule article-hero">
              <img
                class="blog-hero-image"
                src={heroImage}
                alt={heroImageAlt ?? `${title} main image`}
                loading="eager"
                decoding="async"
              />
            </figure>
          ) : null
        }

        <div class="section-rule article-prose">
          <div class="blog-content">
            <slot />
          </div>
        </div>

        {
          newerPost || olderPost ? (
            <nav class="section-rule article-pager" aria-label="More writing">
              {olderPost ? (
                <a class="article-pager-link focus-ring" href={`/blog/${olderPost.slug}`} rel="prev">
                  <span class="article-pager-label">Older</span>
                  <span class="article-pager-title">{olderPost.title}</span>
                </a>
              ) : (
                <span class="article-pager-spacer" aria-hidden="true" />
              )}
              {newerPost ? (
                <a
                  class="article-pager-link article-pager-link--next focus-ring"
                  href={`/blog/${newerPost.slug}`}
                  rel="next"
                >
                  <span class="article-pager-label">Newer</span>
                  <span class="article-pager-title">{newerPost.title}</span>
                </a>
              ) : (
                <span class="article-pager-spacer" aria-hidden="true" />
              )}
            </nav>
          ) : null
        }
      </div>
    </article>
  </main>
  <PromptCopyEnhancer client:load slug={slug} />
</Layout>
