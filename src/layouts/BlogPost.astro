---
import Layout from './Layout.astro';

const { title, description, pubDate, updatedDate, tags } = Astro.props;
const formatter = new Intl.DateTimeFormat('en-US', { dateStyle: 'long' });
const publishedLabel = formatter.format(pubDate);
const updatedLabel = updatedDate ? formatter.format(updatedDate) : null;
---

<Layout title={`${title} | Daniel Zuloaga`} description={description}>
  <div class="relative z-0 min-h-screen overflow-hidden px-4 py-14 sm:px-6 lg:px-10">
    <div class="water-wind-glow" aria-hidden="true"></div>
    <article class="relative z-10 mx-auto flex max-w-3xl flex-col gap-6">
      <a
        class="inline-flex w-fit items-center gap-2 rounded-full border border-white/10 bg-white/5 px-4 py-2 text-xs font-semibold uppercase tracking-[0.2em] text-slate-200 transition hover:-translate-y-[1px] hover:border-white/20 hover:bg-white/10"
        href="/blog"
      >
        <span>Back to blog</span>
      </a>
      <header class="space-y-3">
        <p class="text-xs font-semibold uppercase tracking-[0.28em] text-slate-400">Post</p>
        <h1 class="text-3xl font-semibold tracking-tight text-slate-50 sm:text-4xl">{title}</h1>
        <p class="text-base text-slate-200/85 sm:text-lg">{description}</p>
        <div class="flex flex-wrap items-center gap-3 text-xs font-semibold uppercase tracking-[0.22em] text-slate-400">
          <span>{publishedLabel}</span>
          {updatedLabel && <span>Updated {updatedLabel}</span>}
        </div>
        {
          tags?.length ? (
            <div class="flex flex-wrap gap-2 pt-1">
              {tags.map((tag) => (
                <span class="rounded-full border border-white/10 bg-white/5 px-3 py-1 text-[11px] font-semibold uppercase tracking-[0.18em] text-slate-200">
                  {tag}
                </span>
              ))}
            </div>
          ) : null
        }
      </header>
      <div class="blog-content">
        <slot />
      </div>
    </article>
  </div>
</Layout>
