---
import Layout from './Layout.astro';
import MarkdownProse from '../components/ui/MarkdownProse.astro';
import PageShell from '../components/ui/PageShell.astro';
import PromptCopyEnhancer from '../components/PromptCopyEnhancer';
import { displayTitle, focusRing, metaText, proseLead } from '../lib/classes';
import { cn } from '../lib/utils';

const {
  title,
  description,
  pubDate,
  updatedDate,
  tags,
  heroImage,
  heroImageAlt,
  slug,
  minutes,
  newerPost,
  olderPost,
} = Astro.props;
const formatter = new Intl.DateTimeFormat('en-US', { dateStyle: 'long' });
const publishedLabel = formatter.format(pubDate);
const updatedLabel = updatedDate ? formatter.format(updatedDate) : null;
---

<Layout
  title={`${title} | Daniel Zuloaga`}
  description={description}
  ogType="article"
  ogImage={heroImage ?? '/og.jpg'}
  pubDate={pubDate}
  updatedDate={updatedDate}
  nav="blog"
>
  <main id="main-content">
    <PageShell as="article" class="pb-section-lg">
      <header class="flex flex-col gap-md py-page-intro">
        <nav class="flex items-center gap-xs font-ui text-sm font-medium leading-ui text-accent" aria-label="Breadcrumb">
          <a class={focusRing} href="/">Home</a>
          <span class="select-none text-meta" aria-hidden="true">/</span>
          <a class={focusRing} href="/blog">Writing</a>
          <span class="select-none text-meta" aria-hidden="true">/</span>
          <span class="text-ink" aria-current="page">{title}</span>
        </nav>
        <h1 class={cn(displayTitle, 'max-w-[48rem]')}>{title}</h1>
        <p class={proseLead}>{description}</p>

        <div class={cn(metaText, 'flex flex-wrap items-center gap-sm')}>
          <time datetime={pubDate.toISOString()}>{publishedLabel}</time>
          {minutes && <span>{minutes} min read</span>}
          {updatedLabel && <span>Updated {updatedLabel}</span>}
        </div>

        {
          tags?.length ? (
            <div class="flex flex-wrap items-center gap-sm">
              {tags.map((tag) => (
                <span class="inline-flex min-h-8 items-center rounded-md border border-border bg-bg px-2.5 py-1.5 font-ui text-xs font-medium leading-ui text-muted">{tag}</span>
              ))}
            </div>
          ) : null
        }
      </header>

      <div class="w-full max-w-[65ch]">
        {
          heroImage ? (
            <figure class="w-full py-xl">
              <img
                class="block h-auto w-full rounded-lg border border-border"
                src={heroImage}
                alt={heroImageAlt ?? `${title} main image`}
                loading="eager"
                decoding="async"
              />
            </figure>
          ) : null
        }

        <div class="py-xl">
          <MarkdownProse>
            <slot />
          </MarkdownProse>
        </div>

        {
          newerPost || olderPost ? (
            <nav class="mt-xl grid gap-md pt-lg sm:grid-cols-2 sm:gap-xl" aria-label="More writing">
              {olderPost ? (
                <a class={cn(focusRing, 'group flex flex-col gap-2xs rounded-sm')} href={`/blog/${olderPost.slug}`} rel="prev">
                  <span class={metaText}>Older</span>
                  <span class="text-balance font-display text-base font-semibold leading-heading tracking-[-0.015em] text-ink transition-colors duration-150 ease-out group-hover:text-accent motion-reduce:transition-none">{olderPost.title}</span>
                </a>
              ) : (
                <span class="hidden sm:block" aria-hidden="true" />
              )}
              {newerPost ? (
                <a
                  class={cn(focusRing, 'group flex flex-col gap-2xs rounded-sm sm:text-right')}
                  href={`/blog/${newerPost.slug}`}
                  rel="next"
                >
                  <span class={metaText}>Newer</span>
                  <span class="text-balance font-display text-base font-semibold leading-heading tracking-[-0.015em] text-ink transition-colors duration-150 ease-out group-hover:text-accent motion-reduce:transition-none">{newerPost.title}</span>
                </a>
              ) : (
                <span class="hidden sm:block" aria-hidden="true" />
              )}
            </nav>
          ) : null
        }
      </div>
    </PageShell>
  </main>
  <PromptCopyEnhancer client:load slug={slug} />
</Layout>
