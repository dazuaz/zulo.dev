---
import PageShell from './ui/PageShell.astro';
import { focusRing } from '../lib/classes';
import { cn } from '../lib/utils';

const { current = 'home' } = Astro.props;

const links = [
  { id: 'home', label: 'Home', href: '/' },
  { id: 'blog', label: 'Writing', href: '/blog' },
  { id: 'contact', label: 'Contact', href: '/contact' },
];
---

<header class="sticky top-0 z-sticky bg-bg font-ui shadow-surface">
  <PageShell as="div" class="flex items-center justify-between gap-md py-sm">
    <a class={cn(focusRing, 'font-display text-sm font-semibold leading-ui text-ink')} href="/">Daniel Zuloaga</a>
    <nav class="flex flex-wrap items-center gap-x-lg gap-y-2xs" aria-label="Primary">
      {
        links.map((link) => (
          <a
            class={cn(
              focusRing,
              'rounded-sm text-sm font-medium leading-ui text-muted transition-colors duration-150 ease-out hover:text-ink motion-reduce:transition-none',
              current === link.id && 'text-ink',
            )}
            href={link.href}
            aria-current={current === link.id ? 'page' : undefined}
          >
            {link.label}
          </a>
        ))
      }
    </nav>
  </PageShell>
</header>
