---
const { current = 'home' } = Astro.props;

const links = [
  { id: 'home', label: 'Home', href: '/' },
  { id: 'blog', label: 'Writing', href: '/blog' },
  { id: 'contact', label: 'Contact', href: '/contact' },
];
---

<header class="site-nav">
  <div class="page-shell site-nav-inner">
    <a class="site-nav-brand focus-ring" href="/">Daniel Zuloaga</a>
    <nav class="site-nav-links" aria-label="Primary">
      {
        links.map((link) => (
          <a
            class:list={['site-nav-link', 'focus-ring', { 'is-active': current === link.id }]}
            href={link.href}
            aria-current={current === link.id ? 'page' : undefined}
          >
            {link.label}
          </a>
        ))
      }
    </nav>
  </div>
</header>
