---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Contact | Daniel Zuloaga"
  description="Send a note about a project, workflow, or idea you want to think through together."
  nav="contact"
>
  <main id="main-content">
    <section class="page-shell page-intro">
      <div class="stack-md">
        <h1 class="display-title">Get in touch</h1>
        <p class="prose-body">
          Tell me a bit about what you're working on. I read everything; I reply to most things within a couple of days.
        </p>
      </div>
    </section>

    <section class="page-shell section-rule section-block section-block--end">
      <div class="content-panel measure-form">
        <div id="contact-status" class="sr-only" role="status" aria-live="polite" aria-atomic="true"></div>

        <form id="contact-form" class="form-stack" novalidate>
          <div class="field-group">
            <label for="name" class="field-label">Name <span class="field-required">(required)</span></label>
            <input
              id="name"
              name="name"
              type="text"
              required
              maxlength="120"
              autocomplete="name"
              class="field-input"
              aria-describedby="name-error"
            />
            <p id="name-error" class="field-error hidden" role="alert"></p>
          </div>

          <div class="field-group">
            <label for="email" class="field-label">Email <span class="field-required">(required)</span></label>
            <input
              id="email"
              name="email"
              type="email"
              required
              maxlength="254"
              autocomplete="email"
              class="field-input"
              aria-describedby="email-error"
            />
            <p id="email-error" class="field-error hidden" role="alert"></p>
          </div>

          <div class="field-group">
            <label for="message" class="field-label">Message <span class="field-required">(required)</span></label>
            <textarea
              id="message"
              name="message"
              required
              rows="6"
              maxlength="5000"
              class="field-input resize-y"
              aria-describedby="message-error"
            ></textarea>
            <p id="message-error" class="field-error hidden" role="alert"></p>
          </div>

          <p id="contact-error" class="field-error hidden" role="alert"></p>

          <div>
            <button type="submit" id="contact-submit" class="btn-primary focus-ring">
              <span id="contact-submit-label">Send message</span>
            </button>
          </div>
        </form>

        <div id="contact-success" class="hidden stack-md" role="region" aria-labelledby="contact-success-heading">
          <h2 id="contact-success-heading" class="section-title" tabindex="-1">Thanks, your message is on its way.</h2>
          <p class="prose-body">
            I'll reply to the email you provided. Until then, you can poke around the
            <a class="link-accent focus-ring" href="/blog">writing</a>.
          </p>
        </div>
      </div>
    </section>
  </main>

  <script>
    type FieldName = 'name' | 'email' | 'message';

    const form = document.getElementById('contact-form') as HTMLFormElement | null;
    const submitBtn = document.getElementById('contact-submit') as HTMLButtonElement | null;
    const submitLabel = document.getElementById('contact-submit-label');
    const errorEl = document.getElementById('contact-error');
    const successEl = document.getElementById('contact-success');
    const statusEl = document.getElementById('contact-status');
    const successHeading = document.getElementById('contact-success-heading');

    const fields: FieldName[] = ['name', 'email', 'message'];

    function announceStatus(message: string) {
      if (statusEl) statusEl.textContent = message;
    }

    function clearFieldErrors() {
      for (const field of fields) {
        const input = document.getElementById(field) as HTMLInputElement | HTMLTextAreaElement | null;
        const fieldError = document.getElementById(`${field}-error`);
        if (input) {
          input.removeAttribute('aria-invalid');
        }
        if (fieldError) {
          fieldError.textContent = '';
          fieldError.classList.add('hidden');
        }
      }
      if (errorEl) {
        errorEl.classList.add('hidden');
        errorEl.textContent = '';
      }
    }

    function setFieldError(field: FieldName, message: string) {
      const input = document.getElementById(field) as HTMLInputElement | HTMLTextAreaElement | null;
      const fieldError = document.getElementById(`${field}-error`);
      if (input) {
        input.setAttribute('aria-invalid', 'true');
        input.focus();
      }
      if (fieldError) {
        fieldError.textContent = message;
        fieldError.classList.remove('hidden');
      }
      announceStatus(message);
    }

    function mapErrorToField(message: string): FieldName | null {
      const lower = message.toLowerCase();
      if (lower.includes('name is required')) return 'name';
      if (lower.includes('valid email') || lower.includes('email is required')) return 'email';
      if (lower.includes('message is required')) return 'message';
      return null;
    }

    function validateClient(payload: { name: string; email: string; message: string }) {
      if (!payload.name.trim()) {
        setFieldError('name', 'Name is required.');
        return false;
      }
      if (!payload.email.trim()) {
        setFieldError('email', 'Email is required.');
        return false;
      }
      if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(payload.email)) {
        setFieldError('email', 'Enter a valid email address.');
        return false;
      }
      if (!payload.message.trim()) {
        setFieldError('message', 'Message is required.');
        return false;
      }
      return true;
    }

    if (form && submitBtn && submitLabel && errorEl && successEl) {
      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        clearFieldErrors();

        const data = new FormData(form);
        const payload = {
          name: String(data.get('name') ?? ''),
          email: String(data.get('email') ?? ''),
          message: String(data.get('message') ?? ''),
        };

        if (!validateClient(payload)) return;

        submitBtn.disabled = true;
        submitLabel.textContent = 'Sending…';
        announceStatus('Sending your message.');

        try {
          const res = await fetch('/api/contact', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(payload),
          });

          if (res.ok) {
            form.classList.add('hidden');
            successEl.classList.remove('hidden');
            announceStatus('Thanks, your message is on its way.');
            successHeading?.focus();
            return;
          }

          let message = 'Something went wrong. Try again, or email me directly.';
          let field: FieldName | null = null;
          try {
            const body = await res.json();
            if (body && typeof body.error === 'string') message = body.error;
            if (body && typeof body.field === 'string' && fields.includes(body.field)) {
              field = body.field as FieldName;
            }
          } catch {
            /* ignore */
          }

          const mappedField = field ?? mapErrorToField(message);
          if (mappedField) {
            setFieldError(mappedField, message);
          } else {
            errorEl.textContent = message;
            errorEl.classList.remove('hidden');
            announceStatus(message);
          }
        } catch (err) {
          console.error('Contact form submit failed:', err);
          const networkMessage =
            import.meta.env.DEV
              ? 'Could not reach the contact API. In local dev, copy .env.example to .env and set NOTION_API_KEY.'
              : 'Network error. Check your connection and try again.';
          errorEl.textContent = networkMessage;
          errorEl.classList.remove('hidden');
          announceStatus(networkMessage);
        } finally {
          submitBtn.disabled = false;
          submitLabel.textContent = 'Send message';
        }
      });
    }
  </script>
</Layout>
