---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Contact | Daniel Zuloaga"
  description="Drop a note about your platform, ops, or AI adoption project."
>
  <main class="px-4 py-12 sm:px-6 lg:px-10">
    <div class="mx-auto flex max-w-2xl flex-col gap-6">
      <header class="soft-surface rounded-3xl p-6 sm:p-8">
        <div class="flex items-center gap-3">
          <a href="/" class="text-xs font-semibold uppercase tracking-[0.24em] text-sky-800 transition hover:text-sky-900">Home</a>
          <span class="text-xs text-slate-400">/</span>
          <p class="text-xs font-semibold uppercase tracking-[0.24em] text-sky-800">Contact</p>
        </div>
        <h1 class="mt-3 text-3xl font-semibold tracking-tight text-slate-900 sm:text-4xl">Get in touch</h1>
        <p class="mt-3 text-base text-slate-700 sm:text-lg">
          Tell me a bit about what you're working on. I read everything; I reply to most things within a couple of days.
        </p>
      </header>

      <section class="soft-surface rounded-3xl p-6 sm:p-8">
        <form id="contact-form" class="flex flex-col gap-5" novalidate>
          <div class="flex flex-col gap-2">
            <label for="name" class="text-sm font-semibold text-slate-800">Name</label>
            <input
              id="name"
              name="name"
              type="text"
              required
              maxlength="120"
              autocomplete="name"
              class="rounded-xl border border-slate-300 bg-white px-4 py-2.5 text-base text-slate-900 transition focus:border-sky-700 focus:outline-none focus:ring-2 focus:ring-sky-200"
            />
          </div>

          <div class="flex flex-col gap-2">
            <label for="email" class="text-sm font-semibold text-slate-800">Email</label>
            <input
              id="email"
              name="email"
              type="email"
              required
              maxlength="254"
              autocomplete="email"
              class="rounded-xl border border-slate-300 bg-white px-4 py-2.5 text-base text-slate-900 transition focus:border-sky-700 focus:outline-none focus:ring-2 focus:ring-sky-200"
            />
          </div>

          <div class="flex flex-col gap-2">
            <label for="message" class="text-sm font-semibold text-slate-800">Message</label>
            <textarea
              id="message"
              name="message"
              required
              rows="6"
              maxlength="5000"
              class="resize-y rounded-xl border border-slate-300 bg-white px-4 py-2.5 text-base text-slate-900 transition focus:border-sky-700 focus:outline-none focus:ring-2 focus:ring-sky-200"
            ></textarea>
          </div>

          <p id="contact-error" class="hidden text-sm font-medium text-rose-700" role="alert"></p>

          <div>
            <button
              type="submit"
              id="contact-submit"
              class="inline-flex items-center justify-center rounded-xl bg-sky-700 px-5 py-2.5 text-sm font-semibold text-white shadow-sm transition hover:bg-sky-800 disabled:cursor-not-allowed disabled:opacity-60"
            >
              <span id="contact-submit-label">Send message</span>
            </button>
          </div>
        </form>

        <div id="contact-success" class="hidden">
          <p class="text-xs font-semibold uppercase tracking-[0.24em] text-teal-800">Sent</p>
          <h2 class="mt-2 text-2xl font-semibold tracking-tight text-slate-900">Thanks — your message is on its way.</h2>
          <p class="mt-3 text-slate-700">
            I'll reply to the email you provided. Until then, you can poke around the
            <a class="font-semibold text-sky-700 underline underline-offset-4 hover:text-sky-900" href="/blog">blog</a>.
          </p>
        </div>
      </section>
    </div>
  </main>

  <script>
    import { initBotId } from 'botid/client/core';

    initBotId({
      protect: [{ path: '/api/contact', method: 'POST' }],
    });

    const form = document.getElementById('contact-form') as HTMLFormElement | null;
    const submitBtn = document.getElementById('contact-submit') as HTMLButtonElement | null;
    const submitLabel = document.getElementById('contact-submit-label');
    const errorEl = document.getElementById('contact-error');
    const successEl = document.getElementById('contact-success');

    if (form && submitBtn && submitLabel && errorEl && successEl) {
      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        errorEl.classList.add('hidden');
        errorEl.textContent = '';

        const data = new FormData(form);
        const payload = {
          name: String(data.get('name') ?? ''),
          email: String(data.get('email') ?? ''),
          message: String(data.get('message') ?? ''),
        };

        submitBtn.disabled = true;
        submitLabel.textContent = 'Sending…';

        try {
          const res = await fetch('/api/contact', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(payload),
          });

          if (res.ok) {
            form.classList.add('hidden');
            successEl.classList.remove('hidden');
            return;
          }

          let message = 'Something went wrong. Try again, or email me directly.';
          try {
            const body = await res.json();
            if (body && typeof body.error === 'string') message = body.error;
          } catch {
            /* ignore */
          }
          errorEl.textContent = message;
          errorEl.classList.remove('hidden');
        } catch {
          errorEl.textContent = 'Network error. Check your connection and try again.';
          errorEl.classList.remove('hidden');
        } finally {
          submitBtn.disabled = false;
          submitLabel.textContent = 'Send message';
        }
      });
    }
  </script>
</Layout>
