---
import Layout from '../layouts/Layout.astro'
import { getCollection } from 'astro:content'

const contactHref = '/contact'

const recentPosts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 4)

const dateFormatter = new Intl.DateTimeFormat('en-US', { month: 'short', day: 'numeric', year: 'numeric' })
---

<Layout
  title="Daniel Zuloaga"
  description="AI product and engineering in regulated fintech. Notes on building production systems, agents, and the work behind them."
  nav="home"
>
  <main id="main-content">
    <section class="page-shell page-intro">
      <div class="hero-copy">
        <h1 class="display-title">Daniel Zuloaga</h1>
        <p class="prose-lead">
          I build and implement AI systems end to end — product thinking on the way in, working code on the way out.
        </p>
        <p class="prose-body">
          Fifteen years in fintech — engineer, then platform architect, now building production AI inside a regulated lending operation. Agents, document pipelines, and the governance around them: I own that stack, not just the roadmap. I write about what I learn as I build; that's a more honest introduction than anything I could put here.
        </p>
        <div class="hero-actions">
          <a class="btn-primary focus-ring" href={contactHref}>Get in touch</a>
        </div>
      </div>
    </section>

    <section class="page-shell section-rule split-section">
      <div class="split-column">
        <h2 class="section-title">What I'm building now</h2>
        <p class="prose-body">
          I'm working on agent orchestration across lending workflows — document ingestion, tool-calling pipelines, custom MCP servers — in production, not a sandbox. The technical build is half of it; the other half is adoption: governance, training, and the unglamorous work of making automation stick with the people who use it.
        </p>
      </div>
      <div class="split-column">
        <h2 class="section-title">What's new</h2>
        <p class="prose-body">
          AI collapsed product and engineering into one role for me. I can go from a workflow problem to a shipped agent in days, not quarters — but the failure modes are different, and production means something stricter in finance. I write about that shift: faster loops, harder constraints, and what holds up.
        </p>
      </div>
    </section>

    <section class="page-shell section-rule section-block">
      <div class="section-head">
        <div class="stack-xs">
          <h2 class="section-title">Recent notes</h2>
          <p class="prose-body">Systems, constraints, and notes from the build.</p>
        </div>
        <a class="btn-secondary focus-ring" href="/blog">View all writing</a>
      </div>

      <ul class="post-list post-list-spaced">
        {
          recentPosts.length ? (
            recentPosts.map((post) => (
              <li>
                <a class="post-row focus-ring block" href={`/blog/${post.id}`}>
                  <time class="meta-date" datetime={post.data.pubDate.toISOString()}>
                    {dateFormatter.format(post.data.pubDate)}
                  </time>
                  <span class="post-row-title">{post.data.title}</span>
                  <span class="post-row-desc">{post.data.description}</span>
                </a>
              </li>
            ))
          ) : (
            <li class="prose-body empty-state">No posts yet. Check back soon.</li>
          )
        }
      </ul>
    </section>

    <section class="page-shell section-block--page-end">
      <div class="ink-band">
        <div class="ink-band-inner">
          <div class="ink-band-copy">
            <h2 class="section-title">Have a problem worth solving?</h2>
          </div>
          <div class="ink-band-actions cluster-md">
            <a class="btn-primary focus-ring" href={contactHref}>Get in touch</a>
            <a
              class="btn-outline focus-ring"
              href="https://www.linkedin.com/in/daniel-zuloaga/"
              target="_blank"
              rel="noopener noreferrer"
            >
              Connect on LinkedIn
              <span class="sr-only"> (opens in new tab)</span>
            </a>
          </div>
        </div>
      </div>
    </section>
  </main>
</Layout>
