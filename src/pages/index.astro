---
import Layout from '../layouts/Layout.astro'
import { getCollection } from 'astro:content'

const contactHref = '/contact'

const recentPosts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 4)

const dateFormatter = new Intl.DateTimeFormat('en-US', { month: 'short', day: 'numeric', year: 'numeric' })
---

<Layout
  title="Daniel Zuloaga"
  description="A personal site for notes, experiments, and the work I keep coming back to: making useful software, clearer systems, and better ways to think."
  nav="home"
>
  <main id="main-content">
    <section class="page-shell page-intro">
      <div class="hero-copy">
        <h1 class="display-title">Daniel Zuloaga</h1>
        <p class="prose-lead">
          I build useful software, write down what I learn, and spend time in the messy middle where ideas turn into working systems.
        </p>
        <p class="prose-body">
          Most of my work has lived around finance, software, operations, and lately AI. The through line is making confusing things clearer, then turning that clarity into something people can actually use.
        </p>
        <div class="hero-actions">
          <a class="btn-primary focus-ring" href={contactHref}>Get in touch</a>
        </div>
      </div>
    </section>

    <section class="page-shell section-rule split-section">
      <div class="split-column">
        <h2 class="section-title">Useful systems, plain language</h2>
        <p class="prose-body">
          I tend to orbit problems that have too many tabs open: old workflows, new tools, half-formed ideas, and teams trying to make sense of change.
        </p>
        <ul class="focus-list">
          <li>Finding the small question underneath the big, vague one.</li>
          <li>Turning repeatable work into tools instead of rituals.</li>
          <li>Writing and building in public enough that the thinking gets sharper.</li>
        </ul>
      </div>
      <div class="split-column">
        <h2 class="section-title">Learning out loud</h2>
        <p class="prose-body">
          I'm spending a lot of time with AI tools, not as a pitch, but as a way to rethink how people work, review, correct, and teach software over time.
        </p>
      </div>
    </section>

    <section class="page-shell section-rule section-block">
      <div class="section-head">
        <div class="stack-xs">
          <h2 class="section-title">Recent notes</h2>
          <p class="prose-body">Working through software, systems, and how work changes.</p>
        </div>
        <a class="btn-secondary focus-ring" href="/blog">View all writing</a>
      </div>

      <ul class="post-list post-list-spaced">
        {
          recentPosts.length ? (
            recentPosts.map((post) => (
              <li>
                <a class="post-row focus-ring block" href={`/blog/${post.id}`}>
                  <time class="meta-date" datetime={post.data.pubDate.toISOString()}>
                    {dateFormatter.format(post.data.pubDate)}
                  </time>
                  <span class="post-row-title">{post.data.title}</span>
                  <span class="post-row-desc">{post.data.description}</span>
                </a>
              </li>
            ))
          ) : (
            <li class="prose-body empty-state">No posts yet. Check back soon.</li>
          )
        }
      </ul>
    </section>

    <section class="page-shell section-block--page-end">
      <div class="ink-band">
        <div class="ink-band-inner">
          <div class="ink-band-copy">
            <h2 class="section-title">Send the unfinished version</h2>
            <p class="prose-body">
              You do not need a polished brief. A half-shaped idea, a stuck workflow, or a question you keep circling is usually enough to start a useful conversation.
            </p>
          </div>
          <div class="ink-band-actions cluster-md">
            <a class="btn-primary focus-ring" href="/contact">Write me</a>
            <a
              class="btn-outline focus-ring"
              href="https://www.linkedin.com/in/daniel-zuloaga/"
              target="_blank"
              rel="noopener noreferrer"
            >
              Connect on LinkedIn
              <span class="sr-only"> (opens in new tab)</span>
            </a>
          </div>
        </div>
      </div>
    </section>
  </main>
</Layout>
