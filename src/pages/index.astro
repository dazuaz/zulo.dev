---
import Layout from '../layouts/Layout.astro'
import { getCollection } from 'astro:content'

const contactHref = '/contact'

const socials = [
  { label: 'X', href: 'https://x.com/danielzuloaga', external: true },
  { label: 'LinkedIn', href: 'https://www.linkedin.com/in/daniel-zuloaga/', external: true },
  { label: 'GitHub', href: 'https://github.com/dazuaz', external: true },
  { label: 'Blog', href: '/blog', external: false }
]

const recentPosts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3)

const dateFormatter = new Intl.DateTimeFormat('en-US', { dateStyle: 'medium' })
---

<Layout
  title="Daniel Zuloaga"
  description="A personal site for notes, experiments, and the work I keep coming back to: making useful software, clearer systems, and better ways to think."
>
  <main class="px-4 py-12 sm:px-6 lg:px-10">
    <div class="mx-auto flex max-w-5xl flex-col gap-5 sm:gap-6">
      <header class="soft-surface reveal rounded-3xl p-7 sm:p-10">
        <div class="flex flex-col gap-6 sm:flex-row sm:items-start">
          <img
            src="/headshot.jpeg"
            alt=""
            class="h-24 w-24 shrink-0 rounded-full object-cover sm:h-28 sm:w-28"
          />
          <div>
            <p class="text-xs font-semibold uppercase tracking-[0.24em] text-sky-800">Personal site</p>
            <h1 class="mt-3 text-4xl font-semibold tracking-tight text-slate-900 sm:text-5xl">Daniel Zuloaga</h1>
          </div>
        </div>

        <p class="mt-5 max-w-3xl text-lg text-slate-800 sm:text-xl">
          Hi, I'm Daniel. I like building useful things, writing down what I learn, and spending time in the messy middle where ideas turn
          into working systems.
        </p>
        <p class="mt-3 max-w-3xl text-base text-slate-700">
          Most of my work has lived around finance, software, operations, and lately AI. The through line is simpler: I enjoy making
          confusing things a little clearer, then turning that clarity into something people can actually use.
        </p>

        <div class="mt-7 flex flex-wrap items-center gap-3">
          <a
            class="inline-flex items-center justify-center rounded-xl bg-sky-700 px-5 py-2.5 text-sm font-semibold text-white shadow-sm transition hover:bg-sky-800"
            href={contactHref}
          >
            Get in touch
          </a>
          {
            socials.map((item) => (
              <a
                class="inline-flex items-center gap-2 rounded-full border border-slate-300 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-slate-400 hover:bg-slate-50"
                href={item.href}
                rel={item.external ? 'noreferrer' : undefined}
                target={item.external ? '_blank' : undefined}
              >
                <span>{item.label}</span>
              </a>
            ))
          }
        </div>
      </header>

      <section class="grid gap-4 lg:grid-cols-3">
        <article class="soft-surface reveal rounded-3xl p-6 sm:p-7 lg:col-span-2">
          <p class="text-xs font-semibold uppercase tracking-[0.2em] text-sky-800">What I'm drawn to</p>
          <h2 class="mt-2 text-2xl font-semibold tracking-tight text-slate-900">Useful systems, plain language, steady progress</h2>
          <p class="mt-3 text-slate-700">
            I tend to orbit problems that have too many tabs open: old workflows, new tools, half-formed ideas, and teams trying to make
            sense of change.
          </p>
          <ul class="mt-4 list-disc space-y-2 pl-5 text-slate-700">
            <li>Finding the small question underneath the big, vague one.</li>
            <li>Turning repeatable work into tools instead of rituals.</li>
            <li>Writing and building in public enough that the thinking gets sharper.</li>
          </ul>
        </article>

        <article class="soft-surface reveal rounded-3xl p-6 sm:p-7">
          <p class="text-xs font-semibold uppercase tracking-[0.2em] text-teal-800">Lately</p>
          <h2 class="mt-2 text-2xl font-semibold tracking-tight text-slate-900">Learning out loud</h2>
          <p class="mt-3 text-slate-700">
            I'm spending a lot of time with AI tools, not as a pitch, but as a way to rethink how people work, review, correct, and teach
            software over time.
          </p>
        </article>

        <article class="soft-surface reveal rounded-3xl p-6 sm:p-7 lg:col-span-3">
          <div class="flex flex-col gap-5 sm:flex-row sm:items-end sm:justify-between">
            <div class="max-w-2xl">
              <p class="text-xs font-semibold uppercase tracking-[0.2em] text-teal-800">Start here</p>
              <h2 class="mt-2 text-2xl font-semibold tracking-tight text-slate-900">Send the unfinished version</h2>
              <p class="mt-3 text-slate-700">
                You do not need a polished brief. A half-shaped idea, a stuck workflow, or a question you keep circling is usually enough
                to start a useful conversation.
              </p>
            </div>
            <div class="flex flex-wrap gap-3">
              <a
                class="inline-flex items-center justify-center rounded-xl bg-sky-700 px-4 py-2.5 text-sm font-semibold text-white transition hover:bg-sky-800"
                href="/contact"
              >
                Write me
              </a>
              <a
                class="inline-flex items-center justify-center rounded-xl border border-slate-300 bg-white px-4 py-2.5 text-sm font-semibold text-slate-800 transition hover:border-slate-400"
                href="https://www.linkedin.com/in/daniel-zuloaga/"
                target="_blank"
                rel="noreferrer"
              >
                Connect on LinkedIn
              </a>
            </div>
          </div>
        </article>
      </section>

      <section class="soft-surface reveal rounded-3xl p-6 sm:p-7">
        <div class="flex flex-wrap items-end justify-between gap-4">
          <div>
            <p class="text-xs font-semibold uppercase tracking-[0.24em] text-sky-800">Latest writing</p>
            <h2 class="mt-2 text-2xl font-semibold tracking-tight text-slate-900">Recent notes</h2>
            <p class="mt-2 max-w-2xl text-slate-700">
              Things I am working through in public, usually around software, systems, and how work changes.
            </p>
          </div>
          <a
            class="inline-flex items-center rounded-full border border-slate-300 bg-white px-4 py-2 text-xs font-semibold uppercase tracking-[0.17em] text-slate-700 transition hover:border-slate-400"
            href="/blog"
          >
            View all posts
          </a>
        </div>

        <div class="mt-5 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
          {
            recentPosts.length ? (
              recentPosts.map((post) => (
                <a
                  class="group rounded-2xl border border-slate-200 bg-white p-5 transition hover:border-slate-300 hover:shadow-sm"
                  href={`/blog/${post.id}`}
                >
                  <p class="text-xs font-semibold uppercase tracking-[0.16em] text-slate-500">{dateFormatter.format(post.data.pubDate)}</p>
                  <h3 class="mt-3 text-lg font-semibold text-slate-900 transition group-hover:text-sky-800">{post.data.title}</h3>
                  <p class="mt-2 text-sm text-slate-700">{post.data.description}</p>
                  <span class="mt-4 inline-flex text-sm font-semibold text-sky-700">Read post</span>
                </a>
              ))
            ) : (
              <div class="rounded-2xl border border-slate-200 bg-white p-6 text-slate-700 sm:col-span-2 lg:col-span-3">
                No posts yet. Check back soon.
              </div>
            )
          }
        </div>
      </section>
    </div>
  </main>

  <style>
    .reveal {
      animation: rise-in 0.65s ease-out both;
    }

    .reveal:nth-child(2) {
      animation-delay: 0.08s;
    }

    .reveal:nth-child(3) {
      animation-delay: 0.14s;
    }

    .reveal:nth-child(4) {
      animation-delay: 0.2s;
    }

    @keyframes rise-in {
      from {
        opacity: 0;
        transform: translateY(10px);
      }

      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    @media (prefers-reduced-motion: reduce) {
      .reveal {
        animation: none;
      }
    }
  </style>
</Layout>
