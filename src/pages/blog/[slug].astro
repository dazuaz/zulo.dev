---
import { getCollection, render } from 'astro:content';
import BlogPost from '../../layouts/BlogPost.astro';
import Layout from '../../layouts/Layout.astro';
import { readingTimeMinutes } from '../../lib/reading-time';

const slug = Astro.params.slug;
const publishedPosts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
const postIndex = publishedPosts.findIndex(({ id }) => id === slug);
const post = postIndex === -1 ? undefined : publishedPosts[postIndex];

if (!post) {
  Astro.response.status = 404;
}

// Posts are sorted newest first: "newer" sits before this one, "older" after.
const newerPost = postIndex > 0 ? publishedPosts[postIndex - 1] : undefined;
const olderPost = postIndex === -1 ? undefined : publishedPosts[postIndex + 1];

const renderedPost = post ? await render(post) : undefined;
const Content = renderedPost?.Content;
---

{
  post && Content ? (
    <BlogPost
      slug={post.id}
      title={post.data.title}
      description={post.data.description}
      pubDate={post.data.pubDate}
      updatedDate={post.data.updatedDate}
      heroImage={post.data.heroImage}
      heroImageAlt={post.data.heroImageAlt}
      tags={post.data.tags}
      minutes={readingTimeMinutes(post.body ?? '')}
      newerPost={newerPost ? { slug: newerPost.id, title: newerPost.data.title } : undefined}
      olderPost={olderPost ? { slug: olderPost.id, title: olderPost.data.title } : undefined}
    >
      <Content />
    </BlogPost>
  ) : (
    <Layout title="Post not found | Daniel Zuloaga" description="The requested blog post could not be found." nav="blog">
      <main id="main-content">
        <section class="page-shell page-intro">
          <div class="stack-lg">
            <div class="stack-md">
              <h1 class="display-title">Post not found</h1>
              <p class="prose-body">
                The blog post you requested does not exist or is not publicly available.
              </p>
            </div>
            <a class="btn-secondary focus-ring inline-flex" href="/blog">
              Back to writing
            </a>
          </div>
        </section>
      </main>
    </Layout>
  )
}
