---
import { getCollection, render } from 'astro:content';
import BlogPost from '../../layouts/BlogPost.astro';
import Layout from '../../layouts/Layout.astro';

const slug = Astro.params.slug;
const matchingPosts = slug
  ? await getCollection('blog', ({ id, data }) => id === slug && !data.draft)
  : [];
const post = matchingPosts[0];

if (!post) {
  Astro.response.status = 404;
}

const renderedPost = post ? await render(post) : undefined;
const Content = renderedPost?.Content;
---

{
  post && Content ? (
    <BlogPost
      slug={post.id}
      title={post.data.title}
      description={post.data.description}
      pubDate={post.data.pubDate}
      updatedDate={post.data.updatedDate}
      heroImage={post.data.heroImage}
      heroImageAlt={post.data.heroImageAlt}
      tags={post.data.tags}
    >
      <Content />
    </BlogPost>
  ) : (
    <Layout title="Post not found | Daniel Zuloaga" description="The requested blog post could not be found.">
      <main class="px-4 py-12 sm:px-6 lg:px-10">
        <div class="mx-auto max-w-3xl">
          <div class="soft-surface rounded-3xl p-8 sm:p-10">
            <p class="text-xs font-semibold uppercase tracking-[0.24em] text-sky-800">404</p>
            <h1 class="mt-3 text-3xl font-semibold tracking-tight text-slate-900 sm:text-4xl">Post not found</h1>
            <p class="mt-3 max-w-2xl text-base text-slate-700 sm:text-lg">
              The blog post you requested does not exist or is not publicly available.
            </p>
            <a
              href="/blog"
              class="mt-6 inline-flex items-center rounded-full border border-slate-300 bg-white px-4 py-2 text-sm font-semibold text-slate-800 transition hover:border-slate-400 hover:bg-slate-50"
            >
              Back to blog
            </a>
          </div>
        </div>
      </main>
    </Layout>
  )
}
