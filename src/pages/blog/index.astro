---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
const dateFormatter = new Intl.DateTimeFormat('en-US', { dateStyle: 'medium' });
---

<Layout
  title="Blog | Daniel Zuloaga"
  description="Writing on fintech leadership, platform execution, and building calm systems."
>
  <div class="relative z-0 min-h-screen overflow-hidden px-4 py-14 sm:px-6 lg:px-10">
    <div class="water-wind-glow" aria-hidden="true"></div>
    <div class="relative z-10 mx-auto flex max-w-4xl flex-col gap-8">
      <header class="space-y-3">
        <p class="text-xs font-semibold uppercase tracking-[0.28em] text-slate-400">Blog</p>
        <h1 class="text-3xl font-semibold tracking-tight text-slate-50 sm:text-4xl">Field notes on systems, teams, and momentum</h1>
        <p class="max-w-3xl text-base text-slate-200/85 sm:text-lg">
          Short essays on building fintech platforms with clarity, calm execution, and a bias for measurable outcomes.
        </p>
      </header>

      <section class="grid gap-4">
        {
          posts.length ? (
            posts.map((post) => (
              <a
                class="group block rounded-2xl border border-white/10 bg-white/5 p-5 shadow-xl shadow-black/40 transition hover:-translate-y-0.5 hover:border-white/20 hover:bg-white/10"
                href={`/blog/${post.slug}`}
              >
                <div class="flex flex-wrap items-center gap-3 text-xs font-semibold uppercase tracking-[0.2em] text-slate-400">
                  <span>{dateFormatter.format(post.data.pubDate)}</span>
                  {
                    post.data.tags?.length ? (
                      <div class="flex flex-wrap gap-2">
                        {post.data.tags.slice(0, 3).map((tag) => (
                          <span class="rounded-full border border-white/10 bg-white/5 px-3 py-1 text-[10px] font-semibold uppercase tracking-[0.18em] text-slate-200">
                            {tag}
                          </span>
                        ))}
                      </div>
                    ) : null
                  }
                </div>
                <h2 class="mt-3 text-xl font-semibold text-slate-50 transition group-hover:text-white">{post.data.title}</h2>
                <p class="mt-2 text-slate-200/85">{post.data.description}</p>
                <span class="mt-4 inline-flex items-center text-sm font-semibold text-emerald-200 transition group-hover:text-emerald-100">
                  Read post
                </span>
              </a>
            ))
          ) : (
            <div class="rounded-2xl border border-white/10 bg-white/5 p-6 text-slate-200/80">
              No posts yet. Check back soon.
            </div>
          )
        }
      </section>
    </div>
  </div>
</Layout>
