---
import Layout from '../../layouts/Layout.astro'
import { getCollection } from 'astro:content'
import { readingTimeMinutes } from '../../lib/reading-time'

const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
const dateFormatter = new Intl.DateTimeFormat('en-US', { month: 'short', day: 'numeric', year: 'numeric' })
---

<Layout title="Writing | Daniel Zuloaga" description="Essays on product, systems, software, and making operational work clearer." nav="blog">
  <main id="main-content">
    <section class="page-shell page-intro">
      <div class="stack-md">
        <h1 class="display-title">Writing on product and systems</h1>
        <p class="prose-body">
          Essays on product, systems, and the practical work of building software that holds up.
          Subscribe via <a class="link-accent focus-ring" href="/rss.xml">RSS</a>.
        </p>
      </div>
    </section>

    <section class="page-shell section-rule section-block section-block--end">
      <ul class="post-list">
        {
          posts.length ? (
            posts.map((post) => (
              <li>
                <a class="post-row focus-ring" href={`/blog/${post.id}`}>
                  <span class="post-row-meta">
                    <time class="meta-date" datetime={post.data.pubDate.toISOString()}>
                      {dateFormatter.format(post.data.pubDate)}
                    </time>
                    <span class="meta-date">{readingTimeMinutes(post.body ?? '')} min read</span>
                  </span>
                  <span class="post-row-title">{post.data.title}</span>
                  <span class="post-row-desc">{post.data.description}</span>
                </a>
              </li>
            ))
          ) : (
            <li class="prose-body empty-state">No posts yet. Check back soon.</li>
          )
        }
      </ul>
    </section>
  </main>
</Layout>
